# Gateway — сервер 5.35.127.141
# cp env.example .env  →  заполнить реальными значениями

# URL AI-сервиса (прямой доступ по IP, порт 8001)
AI_SERVICE_URL=http://151.247.196.36:8001

# Общий секрет gateway ↔ ai-service  (min 32 символа)
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
AI_SERVICE_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
# user_id супер-админов через запятую (узнать у @userinfobot)
TELEGRAM_SUPER_ADMINS=

# Путь к SQLite с ПДн (директория создаётся автоматически)
DB_PATH=/var/lib/autogent/pii.db

# CORS-домены через запятую (без trailing slash)
ALLOWED_ORIGINS=https://autogentgroup.ru,https://www.autogentgroup.ru
