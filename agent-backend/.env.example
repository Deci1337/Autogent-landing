# Скопируйте в .env и заполните

# Anthropic API ключ (обязательно)
ANTHROPIC_API_KEY=sk-ant-...

# Модель (по умолчанию claude-haiku — быстро и дёшево)
# Для лучшего качества: claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Разрешённые домены фронтенда (через запятую)
ALLOWED_ORIGINS=https://autogentgroup.ru,https://www.autogentgroup.ru
