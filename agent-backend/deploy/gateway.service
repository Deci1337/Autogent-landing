[Unit]
Description=Autogent Gateway
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/autogent/gateway
EnvironmentFile=/opt/autogent/gateway/.env
ExecStart=/opt/autogent/gateway/.venv/bin/uvicorn main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 1 \
    --log-level info
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
