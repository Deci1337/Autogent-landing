[Unit]
Description=Autogent AI Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/autogent/ai-service
EnvironmentFile=/opt/autogent/ai-service/.env
ExecStart=/opt/autogent/ai-service/.venv/bin/uvicorn main:app \
    --host 127.0.0.1 \
    --port 8001 \
    --workers 1 \
    --log-level info
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
